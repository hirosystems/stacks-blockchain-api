{
  "name": "@hirosystems/stacks-blockchain-api",
  "version": "1.0.0",
  "type": "module",
  "main": "./lib/index.js",
  "scripts": {
    "start": "node ./lib/index.js",
    "build": "npm run generate:git-info && rimraf ./lib && tsc -p tsconfig.build.json",
    "build:client": "npm run generate:git-info && npm run generate:openapi && npm run generate:client",
    "test:api:microblocks": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/api/setup.ts --test-concurrency=1 ./tests/api/microblocks/**/*.test.ts",
    "test:api:sockets": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/api/setup.ts --test-concurrency=1 ./tests/api/sockets/**/*.test.ts",
    "test:api:synthetic-txs": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/api/setup.ts --test-concurrency=1 ./tests/api/synthetic-txs/**/*.test.ts",
    "test:api:v2-proxy": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/api/setup.ts --test-concurrency=1 ./tests/api/v2-proxy/**/*.test.ts",
    "test:snp": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/snp/setup.ts --test-concurrency=1 ./tests/snp/**/*.test.ts",
    "test:krypton:rpc": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/krypton/setup.ts --test-concurrency=1 ./tests/krypton/rpc/**/*.test.ts",
    "test:krypton:bns-e2e": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/krypton/setup.ts --test-concurrency=1 ./tests/krypton/bns-e2e/**/*.test.ts",
    "test:krypton:pox-4": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/krypton/setup.ts --test-concurrency=1 ./tests/krypton/pox-4/**/*.test.ts",
    "test:krypton:pox-4-burnchain": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/krypton/setup.ts --test-concurrency=1 ./tests/krypton/pox-4-burnchain/**/*.test.ts",
    "generate:git-info": "rimraf .git-info && api-toolkit-git-info",
    "generate:openapi": "tsx ./src/openapi-generator.ts",
    "generate:client": "openapi-typescript ./docs/openapi.yaml -o ./client/src/generated/schema.d.ts",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check src/**/*.ts",
    "lint:fix": "eslint . --fix && prettier --write --check src/**/*.{ts,json}",
    "migrate": "node-pg-migrate -m migrations"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirosystems/stacks-blockchain-api.git"
  },
  "author": "Hiro Systems PBC <engineering@hiro.so> (https://hiro.so)",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/hirosystems/stacks-blockchain-api/issues"
  },
  "homepage": "https://github.com/hirosystems/stacks-blockchain-api#readme",
  "prettier": "@stacks/prettier-config",
  "engines": {
    "node": ">=24"
  },
  "engineStrict": true,
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/formbody": "8.0.2",
    "@fastify/http-proxy": "11.4.1",
    "@fastify/type-provider-typebox": "5.2.0",
    "@sinclair/typebox": "0.34.48",
    "@stacks/api-toolkit": "1.12.2",
    "@stacks/codec": "1.6.0",
    "@stacks/common": "6.10.0",
    "@stacks/encryption": "6.13.1",
    "@stacks/network": "6.11.3",
    "@stacks/node-publisher-client": "2.0.5",
    "@stacks/stacking": "6.13.2",
    "@stacks/transactions": "6.11.3",
    "bignumber.js": "10.0.2",
    "bitcoinjs-lib": "6.1.1",
    "c32check": "2.0.0",
    "coinselect": "3.1.12",
    "ecpair": "2.1.0",
    "env-schema": "7.0.0",
    "fastify": "5.8.2",
    "fastify-metrics": "12.1.0",
    "getopts": "2.3.0",
    "ioredis": "5.6.1",
    "jsonrpc-lite": "2.2.0",
    "p-queue": "9.1.0",
    "postgres": "3.4.8",
    "prom-client": "15.1.3",
    "rpc-bitcoin": "2.0.0",
    "socket.io": "4.8.0",
    "source-map-support": "0.5.21",
    "split2": "3.2.2",
    "tiny-secp256k1": "2.2.1",
    "ws": "7.5.10",
    "zone-file": "2.0.0-beta.3"
  },
  "devDependencies": {
    "@fastify/swagger": "9.7.0",
    "@stacks/eslint-config": "3.0.0-develop.2",
    "@types/dockerode": "3.3.39",
    "@types/dotenv-flow": "3.2.0",
    "@types/express": "4.17.13",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.0",
    "@types/source-map-support": "0.5.4",
    "@types/split2": "2.1.6",
    "@types/supertest": "2.0.11",
    "@types/tiny-secp256k1": "2.0.1",
    "@types/ws": "7.4.7",
    "cross-env": "7.0.3",
    "dockerode": "4.0.6",
    "eslint": "10.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-tsdoc": "0.5.2",
    "jest": "30.2.0",
    "nock": "13.5.4",
    "node-pg-migrate": "6.2.2",
    "openapi-typescript": "7.3.0",
    "prettier": "3.6.2",
    "rimraf": "5.0.0",
    "rpc-websocket-client": "1.1.4",
    "socket.io-client": "4.5.4",
    "supertest": "4.0.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "undici": "6.23.0"
  },
  "overrides": {
    "form-data": "4.0.5",
    "postgres": "3.4.8"
  },
  "optionalDependencies": {
    "bufferutil": "4.0.5",
    "utf-8-validate": "5.0.7"
  }
}
